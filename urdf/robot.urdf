<?xml version="1.0"?>
<!--
  Simple visual model for the circular diff-drive robot.
  Physical dimensions:
    - Body diameter   : 0.30 m  (radius 0.15 m)
    - Wheel radius    : 0.0323 m
    - Track width (L) : 0.252 m  → wheel y offset = ±0.126 m
    - LiDAR height    : 0.25 m above base_link (same as static TF in robot_pi_startup.yaml)
  Coordinate convention:
    base_link is at the centre of the drive axle (x forward, y left, z up).
-->
<robot name="diff_drive_robot">

  <!-- ── Materials ─────────────────────────────────────────────────── -->
  <material name="white">
    <color rgba="0.95 0.95 0.95 0.85"/>
  </material>
  <material name="dark_gray">
    <color rgba="0.15 0.15 0.15 1.0"/>
  </material>
  <material name="black">
    <color rgba="0.05 0.05 0.05 1.0"/>
  </material>
  <material name="cyan">
    <color rgba="0.0 0.8 0.8 0.6"/>
  </material>

  <!-- ── Base link (lower circular platform) ───────────────────────── -->
  <link name="base_link">
    <visual>
      <!-- Lower platform disk (visible at wheel-axle height) -->
      <geometry>
        <cylinder radius="0.15" length="0.02"/>
      </geometry>
      <origin xyz="0 0 0.04"/>
      <material name="white"/>
    </visual>
    <visual>
      <!-- Upper platform disk -->
      <geometry>
        <cylinder radius="0.15" length="0.02"/>
      </geometry>
      <origin xyz="0 0 0.20"/>
      <material name="white"/>
    </visual>
    <visual>
      <!-- Centre support column -->
      <geometry>
        <cylinder radius="0.012" length="0.16"/>
      </geometry>
      <origin xyz="0 0 0.13"/>
      <material name="dark_gray"/>
    </visual>
  </link>

  <!-- ── Left wheel ─────────────────────────────────────────────────── -->
  <link name="left_wheel">
    <visual>
      <geometry>
        <cylinder radius="0.0323" length="0.025"/>
      </geometry>
      <material name="dark_gray"/>
    </visual>
  </link>
  <joint name="left_wheel_joint" type="fixed">
    <parent link="base_link"/>
    <child link="left_wheel"/>
    <!-- y = +L/2 = +0.126, wheel axis along Y → rotate 90° around X -->
    <origin xyz="0.0 0.126 0.0" rpy="1.5708 0 0"/>
  </joint>

  <!-- ── Right wheel ────────────────────────────────────────────────── -->
  <link name="right_wheel">
    <visual>
      <geometry>
        <cylinder radius="0.0323" length="0.025"/>
      </geometry>
      <material name="dark_gray"/>
    </visual>
  </link>
  <joint name="right_wheel_joint" type="fixed">
    <parent link="base_link"/>
    <child link="right_wheel"/>
    <origin xyz="0.0 -0.126 0.0" rpy="1.5708 0 0"/>
  </joint>

  <!-- ── LiDAR link ─────────────────────────────────────────────────── -->
  <!--
    Transform matches robot_pi_startup.yaml:
      xyz = 0 0 0.25,  yaw = -1.57 rad  (i.e. rpy = "0 0 -1.5708")
    Replaces the static_transform_publisher that was launched separately.
  -->
  <link name="lidar_link">
    <visual>
      <!-- LiDAR sensor body (small cylinder) -->
      <geometry>
        <cylinder radius="0.038" length="0.04"/>
      </geometry>
      <origin xyz="0 0 0.02"/>
      <material name="black"/>
    </visual>
    <visual>
      <!-- White protective casing -->
      <geometry>
        <box size="0.08 0.08 0.06"/>
      </geometry>
      <origin xyz="0 0 -0.01"/>
      <material name="white"/>
    </visual>
  </link>
  <joint name="lidar_joint" type="fixed">
    <parent link="base_link"/>
    <child link="lidar_link"/>
    <origin xyz="0.0 0.0 0.25" rpy="0 0 -1.5708"/>
  </joint>

</robot>
